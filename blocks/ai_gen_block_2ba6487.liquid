{% doc %}
  @prompt
    Balk waar ik merknamen kan zetten
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-brand-bar__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-brand-bar__title-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.title_spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
  }

  .ai-brand-bar__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.brands_per_row_desktop }}, 1fr);
    gap: {{ block.settings.spacing }}px;
    align-items: center;
    justify-items: center;
  }

  .ai-brand-bar__item-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.item_padding }}px;
  }

  .ai-brand-bar__link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.logo_max_width }}px;
  }

  .ai-brand-bar__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    {% if block.settings.grayscale %}
      filter: grayscale(100%);
      transition: filter 0.3s ease;
    {% endif %}
    opacity: {{ block.settings.opacity | divided_by: 100.0 }};
  }

  {% if block.settings.grayscale %}
    .ai-brand-bar__link-{{ ai_gen_id }}:hover .ai-brand-bar__image-{{ ai_gen_id }} {
      filter: grayscale(0%);
      opacity: 1;
    }
  {% endif %}

  .ai-brand-bar__placeholder-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.logo_max_width }}px;
    aspect-ratio: 3 / 2;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .ai-brand-bar__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-brand-bar__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.brands_per_row_mobile }}, 1fr);
    }
  }
{% endstyle %}

<brand-bar-{{ ai_gen_id }} class="ai-brand-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brand-bar__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-brand-bar__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    <div class="ai-brand-bar__grid-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign image_key = 'brand_image_' | append: i
          assign link_key = 'brand_link_' | append: i
          assign brand_image = block.settings[image_key]
          assign brand_link = block.settings[link_key]
        %}

        <div class="ai-brand-bar__item-{{ ai_gen_id }}">
          {% if brand_link != blank %}
            <a href="{{ brand_link }}" class="ai-brand-bar__link-{{ ai_gen_id }}">
              {% if brand_image %}
                <img
                  src="{{ brand_image | image_url: width: 400 }}"
                  alt="{{ brand_image.alt | escape }}"
                  loading="lazy"
                  width="{{ brand_image.width }}"
                  height="{{ brand_image.height }}"
                  class="ai-brand-bar__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-brand-bar__placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </a>
          {% else %}
            {% if brand_image %}
              <div class="ai-brand-bar__link-{{ ai_gen_id }}">
                <img
                  src="{{ brand_image | image_url: width: 400 }}"
                  alt="{{ brand_image.alt | escape }}"
                  loading="lazy"
                  width="{{ brand_image.width }}"
                  height="{{ brand_image.height }}"
                  class="ai-brand-bar__image-{{ ai_gen_id }}"
                >
              </div>
            {% else %}
              <div class="ai-brand-bar__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</brand-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class BrandBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('brand-bar-{{ ai_gen_id }}', BrandBar{{ ai_gen_id }});
  })();
</script>

