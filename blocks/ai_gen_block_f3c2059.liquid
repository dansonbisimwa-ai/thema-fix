{% doc %}
  @prompt
    grote foto met tekst erin en afbeelding kunnen centeren
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-image-text-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.image_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ block.settings.image_position_horizontal }} {{ block.settings.image_position_vertical }};
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-text-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    padding: 40px;
    text-align: {{ block.settings.text_alignment }};
    max-width: {{ block.settings.text_max_width }}px;
    width: 100%;
  }

  .ai-image-text-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-image-text-subheading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0;
    line-height: 1.5;
  }

  .ai-image-text-button-{{ ai_gen_id }} {
    display: inline-block;
    margin-top: 24px;
    padding: 12px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease;
  }

  .ai-image-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-image-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    z-index: 3;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-wrapper-{{ ai_gen_id }} {
      min-height: {{ block.settings.image_height | times: 0.7 }}px;
    }

    .ai-image-text-content-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-image-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-image-text-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div
  class="ai-image-text-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-text-wrapper-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-image-text-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-image-text-placeholder-{{ ai_gen_id }}">
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      </div>
      <div class="ai-image-text-empty-state-{{ ai_gen_id }}">
        Voeg een afbeelding toe
      </div>
    {% endif %}

    {% if block.settings.show_overlay %}
      <div class="ai-image-text-overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-image-text-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-image-text-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <div class="ai-image-text-subheading-{{ ai_gen_id }}">
          {{ block.settings.subheading }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <a
          href="{{ block.settings.button_link }}"
          class="ai-image-text-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Afbeelding met tekst",
  "settings": [
    {
      "type": "header",
      "content": "Afbeelding"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Afbeelding"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Hoogte",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "select",
      "id": "image_position_horizontal",
      "label": "Horizontale positie",
      "options": [
        {
          "value": "left",
          "label": "Links"
        },
        {
          "value": "center",
          "label": "Midden"
        },
        {
          "value": "right",
          "label": "Rechts"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "image_position_vertical",
      "label": "Verticale positie",
      "options": [
        {
          "value": "top",
          "label": "Boven"
        },
        {
          "value": "center",
          "label": "Midden"
        },
        {
          "value": "bottom",
          "label": "Onder"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop breedte",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Afronding hoeken",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Toon overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay kleur",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay transparantie",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "Tekst"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Kop",
      "default": "Welkom bij onze winkel"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Ondertitel",
      "default": "<p>Ontdek onze nieuwste collectie</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Tekstuitlijning",
      "options": [
        {
          "value": "left",
          "label": "Links"
        },
        {
          "value": "center",
          "label": "Midden"
        },
        {
          "value": "right",
          "label": "Rechts"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "text_max_width",
      "label": "Maximale tekstbreedte",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 700
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Kop kleur",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Kop grootte",
      "min": 24,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Tekst kleur",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Tekst grootte",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Knop"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Knop tekst",
      "default": "Shop nu"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Knop link"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Knop kleur",
      "default": "#00b77f"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Knop tekst kleur",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Knop hover kleur",
      "default": "#009966"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Knop afronding",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Afbeelding met tekst"
    }
  ]
}
{% endschema %}
