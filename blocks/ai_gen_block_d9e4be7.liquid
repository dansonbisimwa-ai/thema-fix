{% doc %}
  @prompt
    grote foto waar ik ook een tekst in kan zetten
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-image-text-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    width: 100%;
    min-height: 500px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-text-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    justify-content: {{ block.settings.horizontal_alignment }};
    padding: {{ block.settings.content_padding }}px;
    z-index: 1;
  }

  .ai-image-text-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.text_max_width }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-text-heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    line-height: 1.2;
    text-shadow: 0 2px 4px rgba(0, 0, 0, {{ block.settings.text_shadow | divided_by: 100.0 }});
  }

  .ai-image-text-subheading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0;
    line-height: 1.5;
    text-shadow: 0 2px 4px rgba(0, 0, 0, {{ block.settings.text_shadow | divided_by: 100.0 }});
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-image-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-image-text-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-image-text-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.6 }}px;
    }
  }
{% endstyle %}

<div class="ai-image-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-wrapper-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-image-text-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-image-text-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-image-text-empty-state-{{ ai_gen_id }}">
          Voeg een afbeelding toe
        </div>
      </div>
    {% endif %}

    <div class="ai-image-text-overlay-{{ ai_gen_id }}"></div>

    <div class="ai-image-text-content-{{ ai_gen_id }}">
      <div class="ai-image-text-inner-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-image-text-heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.subheading != blank %}
          <div class="ai-image-text-subheading-{{ ai_gen_id }}">
            {{ block.settings.subheading }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Afbeelding met tekst",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Afbeelding"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Afbeelding"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop breedte",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Hoekafronding",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay kleur",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay transparantie",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "Tekst"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Koptekst",
      "default": "<p>Jouw koptekst hier</p>"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subtekst",
      "default": "<p>Voeg hier je beschrijving toe</p>"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Tekstkleur",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Koptekst grootte",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subtekst grootte",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Ruimte onder koptekst",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_shadow",
      "label": "Tekstschaduw",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "Positie"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "Horizontale uitlijning",
      "options": [
        {
          "value": "flex-start",
          "label": "Links"
        },
        {
          "value": "center",
          "label": "Midden"
        },
        {
          "value": "flex-end",
          "label": "Rechts"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Verticale uitlijning",
      "options": [
        {
          "value": "flex-start",
          "label": "Boven"
        },
        {
          "value": "center",
          "label": "Midden"
        },
        {
          "value": "flex-end",
          "label": "Onder"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Tekstuitlijning",
      "options": [
        {
          "value": "left",
          "label": "Links"
        },
        {
          "value": "center",
          "label": "Midden"
        },
        {
          "value": "right",
          "label": "Rechts"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "text_max_width",
      "label": "Maximale tekstbreedte",
      "min": 300,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Afbeelding met tekst"
    }
  ]
}
{% endschema %}